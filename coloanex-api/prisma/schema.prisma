generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "borrower", "core", "finance"]
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED

  @@schema("borrower")
}

enum KycDocumentType {
  CITIZENSHIP
  PASSPORT
  DRIVING_LICENSE
  PAN
  OTHER

  @@schema("borrower")
}

enum KycFileType {
  CITIZENSHIP_FRONT
  CITIZENSHIP_BACK
  PASSPORT
  PAN
  LICENSE_FRONT
  LICENSE_BACK
  SELFIE
  SUPPORTING_DOCUMENT
  OTHER

  @@schema("borrower")
}

enum ActivityEntityType {
  ROLE
  PERMISSION
  USER
  TENANT
  BORROWER
  KYC

  @@schema("core")
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  KYC_VERIFY
  KYC_REJECT
  LOGIN
  LOGOUT
  PASSWORD_RESET
  VISIT
  LEAVE

  @@schema("core")
}

enum LoanStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  DISBURSED
  ACTIVE
  CLOSED
  DEFAULTED

  @@schema("finance")
}

enum RepaymentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL

  @@schema("finance")
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  INVESTMENT
  DISBURSEMENT
  REPAYMENT
  FEE

  @@schema("finance")
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED

  @@schema("finance")
}

model Role {
  id          BigInt           @id @default(autoincrement())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
  @@schema("auth")
}

model Permission {
  id          BigInt           @id @default(autoincrement())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
  users       UserPermission[]

  @@map("permissions")
  @@schema("auth")
}

model RolePermission {
  roleId       BigInt     @map("role_id")
  permissionId BigInt     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("auth")
}

model User {
  id              String           @id @default(uuid())
  fullName        String
  email           String           @unique @db.VarChar(255)
  phone           String?          @unique @db.VarChar(10)
  password        String           @db.VarChar(255)
  profileImage    String?          @map("profile_image")
  tenantId        String?          @map("tenant_id")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  isBanned        Boolean          @default(false)
  isEmailVerified Boolean          @default(false)
  isActive        Boolean          @default(true)
  lastActiveAt    DateTime?
  permissions     UserPermission[]
  roles           UserRole[]
  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  borrowers       Borrower[]       @relation("BorrowerUser")
  activities      ActivityLog[]
  ownedTenants    Tenant[]         @relation("TenantOwner")
  repayments      Repayment[]      @relation("RepaymentUser")
  wallets         Wallet[]         @relation("UserWallet")
  investments     Investment[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("users")
  @@schema("auth")
}

model UserRole {
  userId String @map("user_id")
  roleId BigInt @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("auth")
}

model UserPermission {
  userId       String     @map("user_id")
  permissionId BigInt     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
  @@schema("auth")
}

model Tenant {
  id           String        @id @default(uuid())
  name         String
  isActive     Boolean       @default(true)
  isBanned     Boolean       @default(false)
  contactEmail String?       @db.VarChar(255)
  contactPhone String?       @db.VarChar(20)
  address      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ownerUserId  String?       @map("owner_user_id")
  users        User[]
  borrowers    Borrower[]
  activities   ActivityLog[]
  loans        Loan[]
  ownerUser    User?         @relation("TenantOwner", fields: [ownerUserId], references: [id])

  @@index([isActive])
  @@index([isBanned])
  @@map("tenants")
  @@schema("core")
}

model ActivityLog {
  id          String             @id @default(uuid())
  actorUserId String?            @map("actor_user_id")
  tenantId    String?            @map("tenant_id")
  entityType  ActivityEntityType
  entityId    String?
  action      ActivityAction
  description String?
  before      Json?
  after       Json?
  ipAddress   String?            @db.VarChar(45)
  userAgent   String?
  createdAt   DateTime           @default(now())
  actorUser   User?              @relation(fields: [actorUserId], references: [id])
  tenant      Tenant?            @relation(fields: [tenantId], references: [id])
  readBy      NotificationRead[]

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@map("activity_logs")
  @@schema("core")
}

model NotificationRead {
  id            String      @id @default(uuid())
  activityLogId String      @map("activity_log_id")
  userId        String      @map("user_id")
  readAt        DateTime    @default(now()) @map("read_at")
  activityLog   ActivityLog @relation(fields: [activityLogId], references: [id], onDelete: Cascade)

  @@unique([activityLogId, userId])
  @@index([userId])
  @@index([activityLogId])
  @@map("notification_reads")
  @@schema("core")
}

model Borrower {
  id               String    @id @default(uuid())
  tenantId         String
  userId           String    @map("user_id")
  kycStatus        KycStatus @default(PENDING)
  rewardScore      Float?
  kycLastCheckedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  user             User      @relation("BorrowerUser", fields: [userId], references: [id])
  kycs             Kyc[]
  loans            Loan[]    @relation("BorrowerLoans")

  @@unique([tenantId, userId])
  @@index([tenantId, kycStatus])
  @@index([tenantId])
  @@index([userId])
  @@map("borrowers")
  @@schema("borrower")
}

model Kyc {
  id                    String    @id @default(uuid())
  borrowerId            String    @map("borrower_id")
  documentTypes         String[]  @map("document_types")
  firstName             String
  middleName            String?   @map("middle_name")
  lastName              String
  passportSizePhotoUrl  String    @map("passport_size_photo_url")
  dateOfBirth           DateTime  @map("date_of_birth")
  gender                String
  maritalStatus         String    @map("marital_status")
  fatherName            String    @map("father_name")
  motherName            String    @map("mother_name")
  grandfatherName       String    @map("grandfather_name")
  permanentProvince     String    @map("permanent_province")
  permanentDistrict     String    @map("permanent_district")
  permanentMunicipality String    @map("permanent_municipality")
  permanentWard         String    @map("permanent_ward")
  permanentTole         String    @map("permanent_tole")
  occupation            String
  monthlyIncome         Float     @map("monthly_income")
  bankName              String    @map("bank_name")
  bankAccountNumber     String    @map("bank_account_number")
  bankBranch            String    @map("bank_branch")
  status                KycStatus @default(PENDING)
  rejectionReason       String?   @map("rejection_reason")
  verifiedBy            String?   @map("verified_by")
  verifiedAt            DateTime? @map("verified_at")
  notes                 String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  borrower              Borrower  @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  files                 KycFile[]

  @@index([borrowerId])
  @@index([status])
  @@map("kycs")
  @@schema("borrower")
}

model KycFile {
  id             String      @id @default(uuid())
  kycId          String      @map("kyc_id")
  documentNumber String      @map("document_number")
  issueDate      DateTime?   @map("issue_date")
  expiryDate     DateTime?   @map("expiry_date")
  issueDistrict  String?     @map("issue_district")
  fileType       KycFileType @map("file_type")
  documentType   String      @map("document_type")
  fileUrl        String      @map("file_url")
  fileName       String?     @map("file_name")
  mimeType       String?     @map("mime_type")
  sizeInBytes    Int?        @map("size_in_bytes")
  createdAt      DateTime    @default(now()) @map("created_at")
  kyc            Kyc         @relation(fields: [kycId], references: [id], onDelete: Cascade)

  @@index([kycId])
  @@index([fileType])
  @@map("kyc_files")
  @@schema("borrower")
}

model Wallet {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  balance           Decimal  @default(0) @db.Decimal(20, 2)
  bankAccountNumber String?  @unique
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user         User          @relation("UserWallet", fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId])
  @@map("wallets")
  @@schema("finance")
}

model Loan {
  id                    String     @id @default(uuid())
  borrowerId            String     @map("borrower_id")
  tenantId              String     @map("tenant_id")
  providedLoanAmount    Decimal    @map("provided_loan_amount") @db.Decimal(20, 2)
  expectedLoanAmount    Decimal    @map("expected_loan_amount") @db.Decimal(20, 2)
  loanPurpose           String     @map("loan_purpose")
  collateralType        String     @map("collateral_type")
  collateralDescription String     @map("collateral_description")
  collateralValue       Decimal    @map("collateral_value") @db.Decimal(20, 2)
  collateralImageUrl    String     @map("collateral_image_url")
  txHash                String?    @map("tx_hash")
  amount                Decimal    @db.Decimal(20, 2)
  interestRate          Decimal    @map("interest_rate") @db.Decimal(5, 2)
  termMonths            Int        @map("term_months")
  status                LoanStatus @default(DRAFT)
  disbursedAt           DateTime?  @map("disbursed_at")
  dueDate               DateTime?  @map("due_date")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  borrower     Borrower      @relation("BorrowerLoans", fields: [borrowerId], references: [id])
  investments  Investment[]  @relation("LoanInvestments")
  repayments   Repayment[]
  transactions Transaction[]

  @@index([tenantId])
  @@index([borrowerId])
  @@index([status])
  @@map("loans")
  @@schema("finance")
}

model Investment {
  id         String   @id @default(uuid())
  loanId     String   @map("loan_id")
  investorId String   @map("investor_id")
  amount     Decimal  @db.Decimal(20, 2)
  txHash     String?  @map("tx_hash")
  createdAt  DateTime @default(now()) @map("created_at")

  loan Loan @relation("LoanInvestments", fields: [loanId], references: [id])
  user User @relation(fields: [investorId], references: [id])

  @@index([loanId])
  @@index([investorId])
  @@map("investments")
  @@schema("finance")
}

model Repayment {
  id         String    @id @default(uuid())
  loanId     String    @map("loan_id")
  userId     String    @map("user_id")
  txHash     String?   @map("tx_hash")
  amountPaid Decimal   @default(0) @map("amount_paid") @db.Decimal(20, 2)
  paidAt     DateTime? @map("paid_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  loan         Loan          @relation(fields: [loanId], references: [id])
  user         User          @relation("RepaymentUser", fields: [userId], references: [id])
  transactions Transaction[]

  @@index([loanId])
  @@index([userId])
  @@map("repayments")
  @@schema("finance")
}

// transaction model
model Transaction {
  id          String            @id @default(uuid())
  walletId    String            @map("wallet_id")
  loanId      String?           @map("loan_id")
  repaymentId String?           @map("repayment_id")
  type        TransactionType
  amount      Decimal           @db.Decimal(20, 2)
  txHash      String?           @map("tx_hash")
  status      TransactionStatus @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at")

  wallet    Wallet     @relation(fields: [walletId], references: [id])
  loan      Loan?      @relation(fields: [loanId], references: [id])
  repayment Repayment? @relation(fields: [repaymentId], references: [id])

  @@index([walletId])
  @@index([loanId])
  @@index([repaymentId])
  @@map("transactions")
  @@schema("finance")
}
