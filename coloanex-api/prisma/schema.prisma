// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "core", "borrower"]
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED

  @@schema("borrower")
}

enum ActivityEntityType {
  ROLE
  PERMISSION
  USER
  TENANT
  BORROWER
  KYC_DOCUMENT

  @@schema("core")
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  KYC_VERIFY
  KYC_REJECT
  LOGIN
  LOGOUT
  PASSWORD_RESET

  @@schema("core")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  name        String
  isSystem    Boolean  @default(false) @map("is_system")
  description String?
  tenantId    String?  @map("tenant_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])

  @@unique([name, tenantId])
  @@index([tenantId])
  @@map("roles")
  @@schema("auth")
}

model Permission {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique
  isSystem    Boolean  @default(false) @map("is_system")
  description String?
  tenantId    String?  @map("tenant_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles  RolePermission[]
  users  UserPermission[]
  tenant Tenant?          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("permissions")
  @@schema("auth")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("auth")
}

model User {
  id              String    @id @default(uuid())
  fullName        String
  email           String    @unique @db.VarChar(255)
  phone           String    @unique @db.VarChar(10)
  password        String    @db.VarChar(255)
  tenantId        String?   @map("tenant_id")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isBanned        Boolean   @default(false)
  isEmailVerified Boolean   @default(false)
  isActive        Boolean   @default(true)
  lastActiveAt    DateTime?

  roles       UserRole[]
  permissions UserPermission[]
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  activities  ActivityLog[]

  ownedTenants Tenant[]   @relation("TenantOwner")
  borrowers    Borrower[] @relation("BorrowerUser")

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("users")
  @@schema("auth")
}

model UserRole {
  userId String @map("user_id")
  roleId BigInt @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("auth")
}

model UserPermission {
  userId       String @map("user_id")
  permissionId BigInt @map("permission_id")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
  @@schema("auth")
}

model Tenant {
  id           String   @id @default(uuid())
  name         String
  isActive     Boolean  @default(true)
  isBanned     Boolean  @default(false)
  contactEmail String?  @db.VarChar(255)
  contactPhone String?  @db.VarChar(20)
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerUserId String? @map("owner_user_id")
  ownerUser   User?   @relation("TenantOwner", fields: [ownerUserId], references: [id])

  users       User[]
  borrowers   Borrower[]
  roles       Role[]
  permissions Permission[]
  activities  ActivityLog[]

  @@index([isActive])
  @@index([isBanned])
  @@map("tenants")
  @@schema("core")
}

model ActivityLog {
  id          String             @id @default(uuid())
  actorUserId String?            @map("actor_user_id")
  tenantId    String?            @map("tenant_id")
  entityType  ActivityEntityType
  entityId    String?
  action      ActivityAction
  description String?
  before      Json?
  after       Json?
  ipAddress   String?            @db.VarChar(45)
  userAgent   String?
  createdAt   DateTime           @default(now())

  actorUser User?   @relation(fields: [actorUserId], references: [id])
  tenant    Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@map("activity_logs")
  @@schema("core")
}

model Borrower {
  id               String    @id @default(uuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  userId           String    @map("user_id")
  user             User      @relation("BorrowerUser", fields: [userId], references: [id])
  kycStatus        KycStatus @default(PENDING)
  rewardScore      Float?
  kycLastCheckedAt DateTime?
  kycDocumentId    String?   @unique @map("primary_kyc_document_id")

  kycDocument  KycDocument?  @relation("PrimaryKycDocument", fields: [kycDocumentId], references: [id])
  kycDocuments KycDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId, kycStatus])
  @@index([tenantId])
  @@index([userId])
  @@map("borrowers")
  @@schema("borrower")
}

model KycDocument {
  id               String    @id @default(uuid())
  borrowerId       String    @map("borrower_id")
  borrower         Borrower  @relation(fields: [borrowerId], references: [id])
  type             String?
  documentNumber   String?   @map("document_number")
  firstName        String?
  lastName         String?
  fullLegalName    String?   @map("full_legal_name")
  dateOfBirth      DateTime?
  nationalId       String?   @map("national_id")
  nationalIdType   String?   @map("national_id_type")
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  postalCode       String?
  country          String?
  status           KycStatus @default(PENDING)
  fileUrl          String?
  issuingAuthority String?   @map("issuing_authority")
  issueDate        DateTime?
  expiryDate       DateTime?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  primaryForBorrower Borrower? @relation("PrimaryKycDocument")

  @@index([borrowerId, status])
  @@index([status])
  @@index([nationalId, nationalIdType])
  @@map("kyc_documents")
  @@schema("borrower")
}
