generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "borrower", "core", "finance"]
}

model Role {
  id          BigInt           @id @default(autoincrement())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
  @@schema("auth")
}

model Permission {
  id          BigInt           @id @default(autoincrement())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
  users       UserPermission[]

  @@map("permissions")
  @@schema("auth")
}

model RolePermission {
  roleId       BigInt     @map("role_id")
  permissionId BigInt     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("auth")
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique @db.VarChar(255)
  phone           String?          @unique @db.VarChar(10)
  password        String           @db.VarChar(255)
  tenantId        String?          @map("tenant_id")
  profileImage    String?          @map("profile_image")
  createdAt       DateTime         @default(now()) @map("created_at")
  fullName        String           @map("full_name")
  isActive        Boolean          @default(true) @map("is_active")
  isBanned        Boolean          @default(false) @map("is_banned")
  isEmailVerified Boolean          @default(false) @map("is_email_verified")
  lastActiveAt    DateTime?        @map("last_active_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  permissions     UserPermission[]
  roles           UserRole[]
  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  borrowers       Borrower[]       @relation("BorrowerUser")
  activities      ActivityLog[]
  ownedTenants    Tenant[]         @relation("TenantOwner")

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([email])
  @@map("users")
  @@schema("auth")
}

model UserRole {
  userId String @map("user_id")
  roleId BigInt @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("auth")
}

model UserPermission {
  userId       String     @map("user_id")
  permissionId BigInt     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
  @@schema("auth")
}

model Tenant {
  id                String        @id @default(uuid())
  name              String
  address           String?
  ownerUserId       String?       @map("owner_user_id")
  contactEmail      String?       @map("contact_email") @db.VarChar(255)
  contactPhone      String?       @map("contact_phone") @db.VarChar(20)
  createdAt         DateTime      @default(now()) @map("created_at")
  description       String?
  establishedYear   Int?          @map("established_year")
  isActive          Boolean       @default(true) @map("is_active")
  isBanned          Boolean       @default(false) @map("is_banned")
  isPubliclyVisible Boolean       @default(true) @map("is_publicly_visible")
  logo              String?
  totalLoansIssued  Int           @default(0) @map("total_loans_issued")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  website           String?
  mailAccessToken   String?       @map("mail_access_token")
  mailEmail         String?       @map("mail_email")
  mailRefreshToken  String?       @map("mail_refresh_token")
  mailTokenExpiry   DateTime?     @map("mail_token_expiry")
  primaryColor      String?       @map("primary_color") @db.VarChar(20)
  users             User[]
  borrowers         Borrower[]
  activities        ActivityLog[]
  ownerUser         User?         @relation("TenantOwner", fields: [ownerUserId], references: [id])
  contracts         Contract[]
  loans             Loan[]
  rules             Rule[]

  @@index([isActive])
  @@index([isBanned])
  @@index([isPubliclyVisible])
  @@map("tenants")
  @@schema("core")
}

model ActivityLog {
  id          String             @id @default(uuid())
  actorUserId String?            @map("actor_user_id")
  tenantId    String?            @map("tenant_id")
  action      ActivityAction
  description String?
  before      Json?
  after       Json?
  createdAt   DateTime           @default(now()) @map("created_at")
  entityId    String?            @map("entity_id")
  entityType  ActivityEntityType @map("entity_type")
  ipAddress   String?            @map("ip_address") @db.VarChar(45)
  userAgent   String?            @map("user_agent")
  actorUser   User?              @relation(fields: [actorUserId], references: [id])
  tenant      Tenant?            @relation(fields: [tenantId], references: [id])
  readBy      NotificationRead[]

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@map("activity_logs")
  @@schema("core")
}

model NotificationRead {
  id            String      @id @default(uuid())
  activityLogId String      @map("activity_log_id")
  userId        String      @map("user_id")
  readAt        DateTime    @default(now()) @map("read_at")
  activityLog   ActivityLog @relation(fields: [activityLogId], references: [id], onDelete: Cascade)

  @@unique([activityLogId, userId])
  @@index([userId])
  @@index([activityLogId])
  @@map("notification_reads")
  @@schema("core")
}

model Borrower {
  id               String     @id @default(uuid())
  userId           String     @map("user_id")
  createdAt        DateTime   @default(now()) @map("created_at")
  creditScore      Float?     @map("credit_score")
  kycLastCheckedAt DateTime?  @map("kyc_last_checked_at")
  kycStatus        KycStatus  @default(PENDING) @map("kyc_status")
  tenantId         String     @map("tenant_id")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  tenant           Tenant     @relation(fields: [tenantId], references: [id])
  user             User       @relation("BorrowerUser", fields: [userId], references: [id])
  kycs             Kyc[]
  contracts        Contract[]
  loans            Loan[]

  @@unique([tenantId, userId])
  @@index([tenantId, kycStatus])
  @@index([tenantId])
  @@index([userId])
  @@map("borrowers")
  @@schema("borrower")
}

model Kyc {
  id                String    @id @default(uuid())
  borrowerId        String    @map("borrower_id")
  dateOfBirth       DateTime  @map("date_of_birth")
  occupation        String
  monthlyIncome     Float     @map("monthly_income")
  status            KycStatus @default(PENDING)
  rejectionReason   String?   @map("rejection_reason")
  verifiedBy        String?   @map("verified_by")
  verifiedAt        DateTime? @map("verified_at")
  notes             String?
  blockchainTxHash  String?   @map("blockchain_tx_hash")
  blockchainData    Json?     @map("blockchain_data")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  bankDetails       Json      @map("bank_details")
  fullName          String    @map("full_name")
  permanentAddress  Json      @map("permanent_address")
  personalDetails   Json      @map("personal_details")
  photoUrl          String    @map("photo_url")
  files             KycFile[]
  borrower          Borrower  @relation(fields: [borrowerId], references: [id], onDelete: Cascade)

  @@index([borrowerId])
  @@index([status])
  @@map("kycs")
  @@schema("borrower")
}

model KycFile {
  id               String      @id @default(uuid())
  kycId            String      @map("kyc_id")
  fileType         KycFileType @map("file_type")
  fileUrl          String      @map("file_url")
  createdAt        DateTime    @default(now()) @map("created_at")
  documentMetadata Json        @map("document_metadata")
  kyc              Kyc         @relation(fields: [kycId], references: [id], onDelete: Cascade)

  @@index([kycId])
  @@index([fileType])
  @@map("kyc_files")
  @@schema("borrower")
}



model Loan {
  id                  String     @id @default(uuid())
  borrowerId          String     @map("borrower_id")
  status              LoanStatus @default(DRAFT)
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  tenantId            String     @map("tenant_id")
  approvedAmount      Decimal?   @map("approved_amount") @db.Decimal(20, 2)
  collateralDetails   Json       @map("collateral_details")
  purpose             String
  rejectionReason     String?    @map("rejection_reason")
  requestedAmount     Decimal    @map("requested_amount") @db.Decimal(20, 2)
  requestedTermMonths Int        @map("requested_term_months")
  approvedTermMonths  Int?       @map("approved_term_months")
  ruleId              String?    @map("rule_id")
  blockchainTxHash    String? @map("blockchain_tx_hash")
  blockchainData      Json?   @map("blockchain_data")
  contract            Contract?
  borrower            Borrower   @relation(fields: [borrowerId], references: [id])
  rule                Rule?      @relation(fields: [ruleId], references: [id])
  tenant              Tenant     @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([borrowerId])
  @@index([ruleId])
  @@index([status])
  @@map("loans")
  @@schema("finance")
}

model Rule {
  id                String     @id @default(uuid())
  tenantId          String     @map("tenant_id")
  name              String
  description       String?
  ruleType          RuleType   @map("rule_type")
  interestRate      Decimal    @map("interest_rate") @db.Decimal(5, 2)
  loanLimits        Json       @map("loan_limits")
  penaltyConfig     Json       @map("penalty_config")
  paymentConfig     Json       @map("payment_config")
  isActive          Boolean    @default(true) @map("is_active")
  isPubliclyVisible Boolean    @default(true) @map("is_publicly_visible")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  contracts         Contract[]
  loans             Loan[]
  tenant            Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([ruleType])
  @@index([isActive])
  @@index([isPubliclyVisible])
  @@map("rules")
  @@schema("finance")
}

model Contract {
  id                 String            @id @default(uuid())
  contractNumber     String            @unique @map("contract_number")
  tenantId           String            @map("tenant_id")
  borrowerId         String            @map("borrower_id")
  loanId             String            @unique @map("loan_id")
  ruleId             String            @map("rule_id")
  status             ContractStatus    @default(DRAFT)
  startDate          DateTime          @map("start_date")
  endDate            DateTime          @map("end_date")
  loanAmount         Decimal           @map("loan_amount") @db.Decimal(20, 2)
  interestRate       Decimal           @map("interest_rate") @db.Decimal(5, 2)
  termMonths         Int               @map("term_months")
  paymentFrequency   PaymentFrequency  @map("payment_frequency")
  installmentAmount  Decimal           @map("installment_amount") @db.Decimal(20, 2)
  totalInstallments  Int               @map("total_installments")
  totalAmountDue     Decimal           @map("total_amount_due") @db.Decimal(20, 2)
  totalAmountPaid    Decimal           @default(0) @map("total_amount_paid") @db.Decimal(20, 2)
  outstandingBalance Decimal           @map("outstanding_balance") @db.Decimal(20, 2)
  contractPdfUrl     String?           @map("contract_pdf_url")
  signatures         Json?             @map("signatures")
  blockchainTxHash   String?           @map("blockchain_tx_hash")
  blockchainData     Json?             @map("blockchain_data")
  termsAndConditions String            @map("terms_and_conditions")
  disbursementInfo   Json?             @map("disbursement_info")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  reportReason       String?           @map("report_reason")
  signedAt           DateTime?         @map("signed_at")
  borrower           Borrower          @relation(fields: [borrowerId], references: [id])
  loan               Loan              @relation(fields: [loanId], references: [id])
  rule               Rule              @relation(fields: [ruleId], references: [id])
  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  paymentSchedules   PaymentSchedule[]
  transactions       Transaction[]

  @@index([tenantId])
  @@index([borrowerId])
  @@index([loanId])
  @@index([ruleId])
  @@index([status])
  @@map("contracts")
  @@schema("finance")
}

model PaymentSchedule {
  id                String            @id @default(uuid())
  contractId        String            @map("contract_id")
  installmentNumber Int               @map("installment_number")
  dueDate           DateTime          @map("due_date")
  principalAmount   Decimal           @map("principal_amount") @db.Decimal(20, 2)
  interestAmount    Decimal           @map("interest_amount") @db.Decimal(20, 2)
  totalAmount       Decimal           @map("total_amount") @db.Decimal(20, 2)
  status            InstallmentStatus @default(PENDING)
  amountPaid        Decimal           @default(0) @map("amount_paid") @db.Decimal(20, 2)
  penaltyAmount     Decimal           @default(0) @map("penalty_amount") @db.Decimal(10, 2)
  paidAt            DateTime?         @map("paid_at")
  paymentDetails    Json?             @map("payment_details")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  contract          Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  transactions      Transaction[]

  @@unique([contractId, installmentNumber])
  @@index([contractId])
  @@index([status])
  @@index([dueDate])
  @@map("payment_schedules")
  @@schema("finance")
}

model Transaction {
  id                 String            @id @default(uuid())
  sentBy             String            @map("sent_by")
  receivedBy         String            @map("received_by")
  type               TransactionType
  amount             Decimal           @db.Decimal(20, 2)
  createdAt          DateTime          @default(now()) @map("created_at")
  status             TransactionStatus @default(PENDING)
  blockchainTxHash   String? @map("blockchain_tx_hash")
  blockchainData     Json?   @map("blockchain_data")
  completedAt        DateTime?         @map("completed_at")
  contractId         String?           @map("contract_id")
  description        String?
  gatewayDetails     Json?             @map("gateway_details")
  paymentScheduleId  String?           @map("payment_schedule_id")
  contract           Contract?         @relation(fields: [contractId], references: [id])
  paymentSchedule    PaymentSchedule?  @relation(fields: [paymentScheduleId], references: [id])

  @@index([sentBy])
  @@index([receivedBy])
  @@index([contractId])
  @@index([paymentScheduleId])
  @@index([status])
  @@map("transactions")
  @@schema("finance")
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED

  @@schema("borrower")
}

enum KycFileType {
  CITIZENSHIP_FRONT
  CITIZENSHIP_BACK
  PASSPORT
  PAN
  LICENSE_FRONT
  LICENSE_BACK
  SELFIE
  SUPPORTING_DOCUMENT

  @@schema("borrower")
}

enum ActivityEntityType {
  ROLE
  PERMISSION
  USER
  TENANT
  BORROWER
  KYC
  LOAN
  CONTRACT
  RULE
  PAYMENT

  @@schema("core")
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  KYC_VERIFY
  KYC_REJECT
  LOAN_APPROVE
  LOAN_REJECT
  CONTRACT_SIGN
  LOAN_DISBURSE
  PAYMENT_RECEIVED
  LOGIN
  LOGOUT
  PASSWORD_RESET
  VISIT
  LEAVE

  @@schema("core")
}

enum LoanStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CONTRACT_GENERATED
  CONTRACT_SIGNED
  LOAN_PROVIDED

  @@schema("finance")
}

enum InstallmentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL

  @@schema("finance")
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  DISBURSEMENT
  INSTALLMENT_PAYMENT
  PENALTY_PAYMENT
  FEE

  @@schema("finance")
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED

  @@schema("finance")
}

enum RuleType {
  STANDARD
  PREMIUM
  MICRO_LOAN
  BUSINESS_LOAN

  @@schema("finance")
}

enum PenaltyType {
  PERCENTAGE
  FIXED_AMOUNT

  @@schema("finance")
}

enum ContractStatus {
  DRAFT
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED
  GENERATED
  SIGNED
  REPORTED

  @@schema("finance")
}

enum PaymentFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY

  @@schema("finance")
}

enum PaymentGateway {
  ESEWA
  FONEPAY
  KHALTI
  WALLET
  BANK_TRANSFER

  @@schema("finance")
}
