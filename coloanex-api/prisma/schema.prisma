generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "borrower", "core"]
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED

  @@schema("borrower")
}

enum KycDocumentType {P
  CITIZENSHIP
  PASSPORT
  DRIVING_LICENSE
  PAN
  OTHER

  @@schema("borrower")
}

enum KycFileType {
  CITIZENSHIP_FRONT
  CITIZENSHIP_BACK
  PASSPORT
  PAN
  LICENSE_FRONT
  LICENSE_BACK
  SELFIE
  COLLATERAL_PHOTO
  SUPPORTING_DOCUMENT
  OTHER

  @@schema("borrower")
}

enum ActivityEntityType {
  ROLE
  PERMISSION
  USER
  TENANT
  BORROWER
  KYC

  @@schema("core")
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  KYC_VERIFY
  KYC_REJECT
  LOGIN
  LOGOUT
  PASSWORD_RESET
  VISIT
  LEAVE

  @@schema("core")
}

model Role {
  id          BigInt           @id @default(autoincrement())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
  @@schema("auth")
}

model Permission {
  id          BigInt           @id @default(autoincrement())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
  users       UserPermission[]

  @@map("permissions")
  @@schema("auth")
}

model RolePermission {
  roleId       BigInt     @map("role_id")
  permissionId BigInt     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
  @@schema("auth")
}

model User {
  id              String           @id @default(uuid())
  fullName        String
  email           String           @unique @db.VarChar(255)
  phone           String?          @unique @db.VarChar(10)
  password        String           @db.VarChar(255)
  tenantId        String?          @map("tenant_id")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  isBanned        Boolean          @default(false)
  isEmailVerified Boolean          @default(false)
  isActive        Boolean          @default(true)
  lastActiveAt    DateTime?
  permissions     UserPermission[]
  roles           UserRole[]
  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  borrowers       Borrower[]       @relation("BorrowerUser")
  activities      ActivityLog[]
  ownedTenants    Tenant[]         @relation("TenantOwner")

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("users")
  @@schema("auth")
}

model UserRole {
  userId String @map("user_id")
  roleId BigInt @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
  @@schema("auth")
}

model UserPermission {
  userId       String     @map("user_id")
  permissionId BigInt     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
  @@schema("auth")
}

model Tenant {
  id           String        @id @default(uuid())
  name         String
  isActive     Boolean       @default(true)
  isBanned     Boolean       @default(false)
  contactEmail String?       @db.VarChar(255)
  contactPhone String?       @db.VarChar(20)
  address      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ownerUserId  String?       @map("owner_user_id")
  users        User[]
  borrowers    Borrower[]
  activities   ActivityLog[]
  ownerUser    User?         @relation("TenantOwner", fields: [ownerUserId], references: [id])

  @@index([isActive])
  @@index([isBanned])
  @@map("tenants")
  @@schema("core")
}

model ActivityLog {
  id          String             @id @default(uuid())
  actorUserId String?            @map("actor_user_id")
  tenantId    String?            @map("tenant_id")
  entityType  ActivityEntityType
  entityId    String?
  action      ActivityAction
  description String?
  before      Json?
  after       Json?
  ipAddress   String?            @db.VarChar(45)
  userAgent   String?
  createdAt   DateTime           @default(now())
  actorUser   User?              @relation(fields: [actorUserId], references: [id])
  tenant      Tenant?            @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@map("activity_logs")
  @@schema("core")
}

model Borrower {
  id               String    @id @default(uuid())
  tenantId         String
  userId           String    @map("user_id")
  kycStatus        KycStatus @default(PENDING)
  rewardScore      Float?
  kycLastCheckedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  user             User      @relation("BorrowerUser", fields: [userId], references: [id])
  kycs             Kyc[]

  @@unique([tenantId, userId])
  @@index([tenantId, kycStatus])
  @@index([tenantId])
  @@index([userId])
  @@map("borrowers")
  @@schema("borrower")
}

model Kyc {
  id                    String    @id @default(uuid())
  borrowerId            String    @map("borrower_id")
  documentTypes         String[]  @map("document_types")
  firstName             String
  middleName            String?   @map("middle_name")
  lastName              String
  passportSizePhotoUrl  String    @map("passport_size_photo_url")
  dateOfBirth           DateTime  @map("date_of_birth")
  gender                String
  maritalStatus         String   @map("marital_status")
  fatherName            String   @map("father_name")
  motherName            String   @map("mother_name")
  grandfatherName       String   @map("grandfather_name")
  permanentProvince     String   @map("permanent_province")
  permanentDistrict     String   @map("permanent_district")
  permanentMunicipality String   @map("permanent_municipality")
  permanentWard         String   @map("permanent_ward")
  permanentTole         String   @map("permanent_tole")
  occupation            String
  monthlyIncome         Float    @map("monthly_income")
  bankName              String   @map("bank_name")
  bankAccountNumber     String   @map("bank_account_number")
  bankBranch            String   @map("bank_branch")
  loanAmount            Float    @map("loan_amount")
  loanPurpose           String   @map("loan_purpose")
  loanDuration          Int      @map("loan_duration")
  collateralType        String   @map("collateral_type")
  collateralDescription String   @map("collateral_description")
  collateralValue       Float    @map("collateral_value")
  status                KycStatus @default(PENDING)
  rejectionReason       String?   @map("rejection_reason")
  verifiedBy            String?   @map("verified_by")
  verifiedAt            DateTime? @map("verified_at")
  notes                 String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  borrower              Borrower  @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  files                 KycFile[]

  @@index([borrowerId])
  @@index([status])
  @@map("kycs")
  @@schema("borrower")
}

model KycFile {
  id           String      @id @default(uuid())
  kycId        String      @map("kyc_id")
  documentNumber String     @map("document_number")
  issueDate    DateTime?   @map("issue_date")
  expiryDate   DateTime?   @map("expiry_date")
  issueDistrict String?     @map("issue_district")
  fileType     KycFileType @map("file_type")
  documentType String     @map("document_type")
  fileUrl      String      @map("file_url")
  fileName     String?     @map("file_name")
  mimeType     String?     @map("mime_type")
  sizeInBytes  Int?        @map("size_in_bytes")
  createdAt    DateTime    @default(now()) @map("created_at")
  kyc          Kyc         @relation(fields: [kycId], references: [id], onDelete: Cascade)

  @@index([kycId])
  @@index([fileType])
  @@map("kyc_files")
  @@schema("borrower")
}
